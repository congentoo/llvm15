# Unmask llvm_slot_15 for packages in this overlay.
# The main Gentoo tree masks llvm_slot_15 since LLVM 15 was removed.
# This overlay provides LLVM 15 so the slot must be unmasked.
dev-ml/llvm:0 -llvm_slot_15
dev-util/intel-graphics-compiler -llvm_slot_15
dev-libs/opencl-clang:15 -llvm_slot_15
dev-libs/intel-vc-intrinsics -llvm_slot_15
dev-util/spirv-llvm-translator:15 -llvm_slot_15
llvm-core/clang:15 -llvm_slot_15
llvm-core/libclc:0 -llvm_slot_15
llvm-core/lld:15 -llvm_slot_15
llvm-core/lldb:0 -llvm_slot_15
llvm-runtimes/compiler-rt:15.0.7 -llvm_slot_15
llvm-runtimes/compiler-rt-sanitizers:15.0.7 -llvm_slot_15
llvm-runtimes/libcxx:0 -llvm_slot_15
llvm-runtimes/libcxxabi:0 -llvm_slot_15
llvm-runtimes/libunwind:0 -llvm_slot_15
llvm-runtimes/openmp:0 -llvm_slot_15
